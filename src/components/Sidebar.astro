---
import { Github, Linkedin, Mail } from 'lucide-astro';
---

<aside class="w-full md:w-64 tech-border border-r border-slate-800 flex flex-col bg-[#0a1a0f]/30 backdrop-blur-xl md:sticky md:top-0 md:h-screen">
  <div class="p-6 border-b border-slate-800">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
      </div>
      <div class="flex items-center font-mono text-[10px] border border-[#1e293b] rounded-[2px] overflow-hidden">
        <button class="px-2 py-1 bg-[#4ade80] text-[#121417] font-bold transition-colors">EN</button>
        <button class="px-2 py-1 text-[#94a3b8] hover:text-white transition-colors">PT</button>
      </div>
    </div>
    <h2 class="mt-6 font-mono text-sm font-bold tracking-wider text-[#94a3b8] uppercase">Developer Console</h2>
  </div>

  <nav class="flex-1 py-4 overflow-y-auto font-mono text-xs" id="sidebar-nav">
    <a
      class="sidebar-item flex items-center px-6 py-3 transition-colors text-[#4ade80] border-r-2 border-[#4ade80]"
      href="#overview"
    >
      <span class="material-symbols-outlined text-sm mr-3">terminal</span>
      01_OVERVIEW.md
    </a>
    <a
      class="sidebar-item flex items-center px-6 py-3 transition-colors text-[#94a3b8]"
      href="#expertise"
    >
      <span class="material-symbols-outlined text-sm mr-3">layers</span>
      02_EXPERTISE.json
    </a>
    <a
      class="sidebar-item flex items-center px-6 py-3 transition-colors text-[#94a3b8]"
      href="#projects"
    >
      <span class="material-symbols-outlined text-sm mr-3">account_tree</span>
      03_PROJECTS.yaml
    </a>
    <a
      class="sidebar-item flex items-center px-6 py-3 transition-colors text-[#94a3b8]"
      href="#contact"
    >
      <span class="material-symbols-outlined text-sm mr-3">alternate_email</span>
      04_CONNECT.sh
    </a>
  </nav>

  <div class="p-6 border-t border-slate-800">
    <div class="flex flex-col gap-4">
      <a
        class="flex items-center text-xs text-[#94a3b8] hover:text-white transition-colors font-mono"
        href="https://github.com/IgordeOliveira"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Github class="w-4 h-4 mr-2 shrink-0" />
        GitHub/IgordeOliveira
      </a>
      <a
        class="flex items-center text-xs text-[#94a3b8] hover:text-white transition-colors font-mono"
        href="https://www.linkedin.com/in/igordeeoliveira/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <Linkedin class="w-4 h-4 mr-2 shrink-0" />
        LinkedIn/igordeoliveira
      </a>
      <a
        class="flex items-center text-xs text-[#94a3b8] hover:text-white transition-colors font-mono"
        href="mailto:igordeeoliveira@gmail.com"
      >
        <Mail class="w-4 h-4 mr-2 shrink-0" />
        igordeeoliveira@gmail.com
      </a>
    </div>
  </div>
</aside>

<script>
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', function (this: HTMLAnchorElement, e: Event) {
      const href = this.getAttribute('href');
      if (!href || href === '#') return;

      e.preventDefault();
      const target = document.querySelector(href);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });

        document.querySelectorAll('.sidebar-item').forEach((item) => {
          item.classList.remove('text-[#4ade80]', 'border-r-2', 'border-[#4ade80]');
          item.classList.add('text-[#94a3b8]');
        });
        (this as HTMLAnchorElement).classList.add('text-[#4ade80]', 'border-r-2', 'border-[#4ade80]');
        (this as HTMLAnchorElement).classList.remove('text-[#94a3b8]');
      }
    });
  });
</script>

---
import { Image } from 'astro:assets';
import { phrasesPt, phrasesEn } from '../data/site';

const GITHUB_USERNAME = 'IgordeOliveira';
---

<main class="relative h-screen w-full flex flex-col items-center justify-start pt-32 md:justify-center md:pt-0 overflow-hidden">
  <!-- Watermark background text (decorative — not headings for SEO) -->
  <div
    class="absolute inset-0 flex flex-col items-center justify-center z-0 opacity-[0.03] select-none pointer-events-none"
    aria-hidden="true"
  >
    <div class="watermark-text font-bold uppercase text-text-primary whitespace-nowrap font-headline">
      Software
    </div>
    <div class="watermark-text font-bold uppercase text-text-primary whitespace-nowrap font-headline">
      Developer
    </div>
  </div>

  <!-- Central Identity Card -->
  <div class="relative z-10 w-full flex flex-col md:flex-row items-center gap-8 md:gap-12 px-6 text-center md:text-left md:max-w-3xl">
    <!-- Profile photo -->
    <div class="relative shrink-0">
      <div class="photo-pulse absolute inset-0 rounded-full"></div>
      <div class="w-36 h-36 md:w-48 md:h-48 rounded-full overflow-hidden ring-2 ring-text-primary/30">
        <Image
          src={`https://avatars.githubusercontent.com/${GITHUB_USERNAME}`}
          alt="Igor Oliveira"
          width={192}
          height={192}
          loading="eager"
          fetchpriority="high"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Text block -->
    <div class="flex flex-col items-center md:items-start w-full md:flex-1 min-w-0">
      <!-- Name -->
      <div class="mb-3 flex flex-col items-center md:items-start">
        <p
          class="text-base md:text-lg font-medium text-text-muted tracking-wide font-headline"
          data-pt="Olá, sou"
          data-en="Hi, I'm"
        >
          Olá, sou
        </p>
        <h1
          class="text-3xl md:text-5xl font-bold tracking-tighter text-text-primary leading-tight font-headline"
          data-pt="Igor Oliveira"
          data-en="Igor Oliveira"
        >
          Igor Oliveira
        </h1>
      </div>

      <!-- Subtitle -->
      <div class="flex flex-col items-center md:items-start gap-1">
        <p
          class="text-xs md:text-sm font-medium uppercase tracking-[0.2em] text-text-muted"
          data-pt="Expertise"
          data-en="Expertise"
        >
          Expertise
        </p>
        <div id="expertise-wrapper" class="relative group cursor-default">
          <div class="overflow-hidden h-[1.4em] text-xl md:text-2xl w-full group-hover:opacity-0 transition-opacity duration-150">
            <span
              id="text-roller"
              class="block font-semibold text-tertiary tracking-tight leading-[1.4] whitespace-nowrap font-headline"
              data-phrases-pt={JSON.stringify(phrasesPt)}
              data-phrases-en={JSON.stringify(phrasesEn)}
            ></span>
          </div>

          <!-- Static list on hover -->
          <div
            id="expertise-list"
            class="absolute left-0 top-0 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-150 z-20"
          >
            <ul
              class="flex flex-col gap-[0.35em] text-left"
              data-phrases-pt={JSON.stringify(phrasesPt)}
              data-phrases-en={JSON.stringify(phrasesEn)}
            >
              {phrasesPt.map((phrase, i) => (
                <li
                  class="text-sm md:text-base font-semibold text-tertiary font-headline leading-snug whitespace-nowrap expertise-item"
                  data-index={i}
                  style={`--i: ${i}`}
                >
                  {phrase}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
  .watermark-text {
    font-size: 15vw;
    line-height: 0.8;
    letter-spacing: -0.05em;
  }

  @keyframes roll-in {
    0%   { transform: translateY(110%); opacity: 0; }
    14%  { transform: translateY(0);    opacity: 1; }
    82%  { transform: translateY(0);    opacity: 1; }
    100% { transform: translateY(-110%); opacity: 0; }
  }

  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-tertiary-bright) 40%, transparent); }
    50%       { box-shadow: 0 0 0 8px color-mix(in srgb, var(--color-tertiary-bright) 12%, transparent); }
  }

  .photo-pulse {
    animation: pulse-ring 3s ease-in-out infinite;
    border-radius: 9999px;
  }

  #text-roller.rolling {
    animation: roll-in 3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .expertise-item {
    opacity: 0;
    transform: translateY(5px);
  }

  #expertise-wrapper:hover .expertise-item {
    animation: item-in 0.22s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(var(--i) * 45ms);
  }

  @keyframes item-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const roller = document.getElementById('text-roller') as HTMLElement;
  const wrapper = document.getElementById('expertise-wrapper') as HTMLElement;
  const expertiseList = document.getElementById('expertise-list') as HTMLElement;
  const listItems = expertiseList.querySelectorAll<HTMLElement>('.expertise-item');

  const phrasesPt = JSON.parse(roller.dataset.phrasesPt ?? '[]') as string[];
  const phrasesEn = JSON.parse(roller.dataset.phrasesEn ?? '[]') as string[];
  const phrases: Record<string, string[]> = { pt: phrasesPt, en: phrasesEn };

  let currentLang = (localStorage.getItem('lang') ?? 'pt');
  let index = 0;
  let paused = false;

  function updateStaticList() {
    const list = phrases[currentLang];
    listItems.forEach((item, i) => {
      item.textContent = list[i] ?? '';
    });
  }

  function showNext() {
    if (paused) return;
    const list = phrases[currentLang];
    roller.textContent = list[index % list.length];
    index++;

    roller.classList.remove('rolling');
    void roller.offsetWidth;
    roller.classList.add('rolling');
  }

  updateStaticList();
  showNext();
  roller.addEventListener('animationend', showNext);

  wrapper.addEventListener('mouseenter', () => {
    paused = true;
    roller.classList.remove('rolling');
  });

  wrapper.addEventListener('mouseleave', () => {
    paused = false;
    showNext();
  });

  window.addEventListener('langchange', (e) => {
    currentLang = (e as CustomEvent<{ lang: string }>).detail.lang;
    index = 0;
    updateStaticList();
  });
</script>

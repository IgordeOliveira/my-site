---
import { Image } from 'astro:assets';
import Typewriter from 'astro-typewriter';

const GITHUB_USERNAME = 'IgordeOliveira';

const phrasesPt = [
  'Construo pipelines de deploy CI/CD',
  'Automatizo processos através de integrações',
  'Backends prontos para a produção',
  'Bastante experiência em Laravel',
  'Identifico oportunidades de automação',
  'Web Scraping (a parte difícil)',
  'HubSpot, Pipedrive ou qualquer outro conectado',
];

const phrasesEn = [
  'I build CI/CD deployment pipelines',
  'I automate processes through integrations',
  'Production-ready backends',
  'Extensive experience with Laravel',
  'I identify automation opportunities',
  'Web Scraping (the hard part)',
  'HubSpot, Pipedrive or any other connected',
];
---

<main class="relative h-screen w-full flex flex-col items-center justify-center overflow-hidden">
  <!-- Watermark background text -->
  <div class="absolute inset-0 flex flex-col items-center justify-center z-0 opacity-[0.03] select-none pointer-events-none">
    <h1
      class="font-bold uppercase text-text-primary whitespace-nowrap"
      style="font-family: 'Space Grotesk Variable', sans-serif; font-size: 15vw; line-height: 0.8; letter-spacing: -0.05em;"
    >
      Software
    </h1>
    <h1
      class="font-bold uppercase text-text-primary whitespace-nowrap"
      style="font-family: 'Space Grotesk Variable', sans-serif; font-size: 15vw; line-height: 0.8; letter-spacing: -0.05em;"
    >
      Developer
    </h1>
  </div>

  <!-- Central Identity Card -->
  <div class="relative z-10 flex flex-col items-center text-center px-6">
    <!-- Profile photo -->
    <div class="mb-8 relative group">
      <div class="absolute inset-0 bg-tertiary/20 rounded-full blur-2xl group-hover:bg-tertiary/30 transition-all duration-700"></div>
      <div
        class="w-40 h-40 md:w-48 md:h-48 rounded-full overflow-hidden relative bg-background"
        style="box-shadow: inset 0 0 0 4px var(--color-background);"
      >
        <Image
          src={`https://avatars.githubusercontent.com/${GITHUB_USERNAME}`}
          alt="Igor Oliveira"
          width={192}
          height={192}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Name -->
    <h2
      class="text-4xl md:text-6xl font-bold tracking-tighter text-text-primary mb-4"
      style="font-family: 'Space Grotesk Variable', sans-serif;"
      data-pt="Olá, sou Igor Oliveira"
      data-en="Hi, I'm Igor Oliveira"
    >
      Olá, sou Igor Oliveira
    </h2>

    <!-- Subtitle pill -->
    <div class="flex items-center gap-3 bg-surface-mid backdrop-blur-sm px-6 py-2 rounded-full border border-outline-variant">
      <p class="text-lg md:text-xl font-light text-text-muted tracking-wide">
        <Typewriter
          id="typewriter-pt"
          messages={phrasesPt}
          writeSpeed={60}
          deleteSpeed={32}
          waitWritten={2200}
          waitDeleted={450}
        />
        <Typewriter
          id="typewriter-en"
          messages={phrasesEn}
          writeSpeed={60}
          deleteSpeed={32}
          waitWritten={2200}
          waitDeleted={450}
          style="display: none"
        />
      </p>
    </div>
  </div>
</main>

<script>
  const twPt = document.getElementById('typewriter-pt')!;
  const twEn = document.getElementById('typewriter-en')!;

  function applyTypewriterLang(lang: 'pt' | 'en') {
    twPt.style.display = lang === 'pt' ? '' : 'none';
    twEn.style.display = lang === 'en' ? '' : 'none';
  }

  applyTypewriterLang((localStorage.getItem('lang') as 'pt' | 'en') ?? 'pt');

  window.addEventListener('langchange', (e: Event) => {
    applyTypewriterLang((e as CustomEvent<{ lang: 'pt' | 'en' }>).detail.lang);
  });
</script>

---
import { Image } from 'astro:assets';

const GITHUB_USERNAME = 'IgordeOliveira';

const phrasesPt = [
  'identificar oportunidades de automações',
  'automatizar processos',
  'backends prontos para a produção',
  'web scraping (a parte difícil)',
  'integrações entre HubSpot/Pipedrive/Pipefy',
  'pipelines de deploy CI/CD',
  'API para apps mobiles',
];

const phrasesEn = [
  'identifying automation opportunities',
  'automating processes',
  'production-ready backends',
  'web scraping (the hard part)',
  'HubSpot / Pipedrive / Pipefy integrations',
  'CI/CD deployment pipelines',
  'APIs for mobile apps',
];
---

<main class="relative h-screen w-full flex flex-col items-center justify-center overflow-hidden">
  <!-- Watermark background text -->
  <div class="absolute inset-0 flex flex-col items-center justify-center z-0 opacity-[0.03] select-none pointer-events-none">
    <h1
      class="font-bold uppercase text-text-primary whitespace-nowrap"
      style="font-family: 'Space Grotesk Variable', sans-serif; font-size: 15vw; line-height: 0.8; letter-spacing: -0.05em;"
    >
      Software
    </h1>
    <h1
      class="font-bold uppercase text-text-primary whitespace-nowrap"
      style="font-family: 'Space Grotesk Variable', sans-serif; font-size: 15vw; line-height: 0.8; letter-spacing: -0.05em;"
    >
      Developer
    </h1>
  </div>

  <!-- Central Identity Card -->
  <div class="relative z-10 flex flex-col items-center text-center px-6">
    <!-- Profile photo -->
    <div class="mb-8 relative group">
      <div class="absolute inset-0 bg-tertiary/20 rounded-full blur-2xl group-hover:bg-tertiary/30 transition-all duration-700"></div>
      <div
        class="w-40 h-40 md:w-48 md:h-48 rounded-full overflow-hidden relative bg-background"
        style="box-shadow: inset 0 0 0 4px var(--color-background);"
      >
        <Image
          src={`https://avatars.githubusercontent.com/${GITHUB_USERNAME}`}
          alt="Igor Oliveira"
          width={192}
          height={192}
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Name -->
    <h2
      class="text-4xl md:text-6xl font-bold tracking-tighter text-text-primary mb-4"
      style="font-family: 'Space Grotesk Variable', sans-serif;"
      data-pt="Olá, sou Igor Oliveira"
      data-en="Hi, I'm Igor Oliveira"
    >
      Olá, sou Igor Oliveira
    </h2>

    <!-- Subtitle -->
    <div class="flex flex-col items-center gap-1 mt-2">
      <p
        class="text-xs md:text-sm font-medium uppercase tracking-[0.2em] text-text-muted"
        data-pt="Expertise"
        data-en="Expertise"
      >
        Expertise
      </p>
      <div
        class="overflow-hidden"
        style="height: 1.7em;"
      >
        <span
          id="text-roller"
          class="block text-xl md:text-3xl font-semibold text-tertiary tracking-tight"
          style="font-family: 'Space Grotesk Variable', sans-serif;"
        ></span>
      </div>
    </div>
  </div>
</main>

<style>
  @keyframes roll-in {
    0%   { transform: translateY(110%); opacity: 0; }
    14%  { transform: translateY(0);    opacity: 1; }
    82%  { transform: translateY(0);    opacity: 1; }
    100% { transform: translateY(-110%); opacity: 0; }
  }

  #text-roller.rolling {
    animation: roll-in 3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
</style>

<script define:vars={{ phrasesPt, phrasesEn }}>
  const roller = document.getElementById('text-roller');
  const phrases = { pt: phrasesPt, en: phrasesEn };

  let currentLang = (localStorage.getItem('lang') ?? 'pt');
  let index = 0;

  function showNext() {
    const list = phrases[currentLang];
    roller.textContent = list[index % list.length];
    index++;

    roller.classList.remove('rolling');
    void roller.offsetWidth; // force reflow to restart animation
    roller.classList.add('rolling');
  }

  showNext();
  roller.addEventListener('animationend', showNext);

  window.addEventListener('langchange', (e) => {
    currentLang = e.detail.lang;
    index = 0;
  });
</script>

---
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<section class="space-y-6" id="projects">
  <div class="flex justify-between items-end">
    <h2 class="font-mono text-xs font-bold text-[#94a3b8] uppercase tracking-widest flex items-center">
      <span class="w-2 h-2 bg-[#4ade80] mr-2"></span> Production Repositories
    </h2>
    <span class="text-[10px] font-mono text-[#2d5a3d]">TOTAL_ENTRIES: {String(projects.length).padStart(2, '0')}</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    {
      projects.map(async (project) => {
        const { Content } = await render(project);
        return (
          <div class="group bg-[#142d1e]/10 tech-border p-6 rounded-[2px] hover:border-[#4ade80]/50 transition-all">
            <div class="flex justify-between mb-4">
              <span class="font-mono text-xs text-[#4ade80]">
                {project.data.id} // {project.data.code}
              </span>
              <span class="text-[10px] text-[#94a3b8]">{project.data.status}</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-[#4ade80] transition-colors">
              {project.data.title}
            </h3>
            <div class="text-sm text-[#94a3b8] mb-6 prose prose-sm prose-invert max-w-none [&>p]:m-0">
              <Content />
            </div>
            <div class="flex items-center gap-4">
              {project.data.tags.map((tag) => (
                <span class="flex items-center font-mono text-[10px] text-[#2d5a3d]">
                  <span class={`w-2 h-2 ${tag.color} rounded-full mr-2`} />
                  {tag.label}
                </span>
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</section>

---
import { Toggle } from 'astro-theme-toggle/components';
import { Moon, Sun } from 'lucide-astro';
import { navLinks } from '../data/site';
---

<nav class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-md transition-colors duration-300">
  <div class="container-content flex justify-between items-center py-6">
    <div class="text-2xl font-bold tracking-tighter text-text-primary font-headline">
      <span class="text-tertiary-bright">I</span>O<span class="text-tertiary-bright">.</span>
    </div>

    <div class="flex items-center gap-6">
      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-8 text-sm tracking-wider uppercase font-headline">
        {navLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="text-text-muted hover:text-tertiary transition-colors duration-300"
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <!-- Language toggle -->
        <button
          id="lang-toggle"
          data-lang="pt"
          aria-label="Toggle language"
          class="flex items-center h-8 rounded-full border border-outline-variant bg-surface-mid px-1 gap-0 transition-colors duration-300 hover:border-text-muted font-headline"
        >
          <span id="lang-pt" class="text-xs font-semibold tracking-widest uppercase px-2 py-1 rounded-full border border-transparent transition-all duration-300 text-text-primary">PT</span>
          <span id="lang-en" class="text-xs font-semibold tracking-widest uppercase px-2 py-1 rounded-full border border-transparent transition-all duration-300 text-text-muted">EN</span>
        </button>

        <!-- Theme toggle (ripple animation via astro-theme-toggle) -->
        <div
          class="nav-theme-toggle-pill relative size-8 shrink-0 rounded-full border border-outline-variant bg-surface-mid transition-colors duration-300 hover:border-text-muted"
        >
          <Toggle
            aria-label="Alternar tema"
            class="absolute inset-0 size-full text-text-primary [&_svg]:block [&_svg]:shrink-0"
          >
            <Sun slot="icon-light" size={14} class="text-text-primary" />
            <Moon slot="icon-dark" size={14} class="text-text-primary" />
          </Toggle>
        </div>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-toggle"
          aria-label="Toggle menu"
          class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-[5px] group"
        >
          <span id="ham-top" class="block w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
          <span id="ham-mid" class="block w-5 h-[1.5px] bg-text-primary transition-all duration-300"></span>
          <span id="ham-bot" class="block w-5 h-[1.5px] bg-text-primary transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out bg-surface/95 backdrop-blur-md border-t border-outline-variant/30"
  >
    <div class="container-content flex flex-col gap-4 py-4 font-headline">
      {navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="text-sm tracking-wider uppercase text-text-muted hover:text-tertiary transition-colors duration-300 py-1"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  #lang-toggle[data-lang="pt"] #lang-pt,
  #lang-toggle[data-lang="en"] #lang-en {
    background-color: color-mix(in srgb, var(--color-tertiary) 20%, transparent);
    border-color: color-mix(in srgb, var(--color-tertiary) 40%, transparent);
  }
</style>

<style is:global>
  /*
    Visible layer only (keeps sun/moon from stacking).
    Fill the pill inner box, then center SVG with translate — avoids baseline/text-align drift
    DevTools often flags `text-align: start` + `vertical-align: baseline` on these nodes.
  */
  .nav-theme-toggle-pill > astro-theme-toggle {
    box-sizing: border-box;
  }

  .nav-theme-toggle-pill html:not(.dark) astro-theme-toggle .astro-theme-toggle-icon-light {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    min-width: 100%;
    min-height: 100%;
    display: block !important;
    margin: 0;
    padding: 0;
    line-height: 0;
    text-align: center;
    box-sizing: border-box;
  }

  .nav-theme-toggle-pill html.dark astro-theme-toggle .astro-theme-toggle-icon-dark {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    min-width: 100%;
    min-height: 100%;
    display: block !important;
    margin: 0;
    padding: 0;
    line-height: 0;
    text-align: center;
    box-sizing: border-box;
  }

  .nav-theme-toggle-pill astro-theme-toggle .astro-theme-toggle-icon-light svg,
  .nav-theme-toggle-pill astro-theme-toggle .astro-theme-toggle-icon-dark svg {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    display: block !important;
    margin: 0 !important;
    vertical-align: middle;
  }
</style>

<script>
  // ── Language toggle ───────────────────────────────────────────
  const langToggle = document.getElementById('lang-toggle')!;
  const labelPt    = document.getElementById('lang-pt')!;
  const labelEn    = document.getElementById('lang-en')!;

  let currentLang = (localStorage.getItem('lang') ?? 'pt') as 'pt' | 'en';

  function applyLang(lang: 'pt' | 'en') {
    currentLang = lang;
    localStorage.setItem('lang', lang);

    const isPt = lang === 'pt';
    langToggle.dataset.lang = lang;
    labelPt.classList.toggle('text-text-primary', isPt);
    labelPt.classList.toggle('text-text-muted',  !isPt);
    labelEn.classList.toggle('text-text-primary', !isPt);
    labelEn.classList.toggle('text-text-muted',   isPt);

    // Swap translatable content
    document.querySelectorAll<HTMLElement>('[data-pt][data-en]').forEach((el) => {
      el.textContent = lang === 'pt' ? (el.dataset.pt ?? '') : (el.dataset.en ?? '');
    });

    window.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
  }

  applyLang(currentLang);

  langToggle.addEventListener('click', () => {
    applyLang(currentLang === 'pt' ? 'en' : 'pt');
  });

  // ── Mobile menu toggle ────────────────────────────────────────
  const mobileToggle = document.getElementById('mobile-menu-toggle')!;
  const mobileMenu   = document.getElementById('mobile-menu')!;
  const hamTop       = document.getElementById('ham-top')!;
  const hamMid       = document.getElementById('ham-mid')!;
  const hamBot       = document.getElementById('ham-bot')!;

  let menuOpen = false;

  mobileToggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu.style.maxHeight = menuOpen ? `${mobileMenu.scrollHeight}px` : '0px';
    // Animate to X
    hamTop.style.transform = menuOpen ? 'translateY(6.5px) rotate(45deg)' : '';
    hamMid.style.opacity   = menuOpen ? '0' : '1';
    hamBot.style.transform = menuOpen ? 'translateY(-6.5px) rotate(-45deg)' : '';
  });
</script>

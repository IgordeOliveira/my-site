---
import { ThemeScript } from 'astro-theme-toggle/components';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Igor Oliveira | Software Developer',
  description = 'Software developer specializing in automation, production-ready backends, and integrations.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Migrate legacy key so preference survives switching to astro-theme-toggle -->
    <script is:inline>
      (function () {
        if (localStorage.getItem('theme-toggle') == null && localStorage.getItem('theme')) {
          var t = localStorage.getItem('theme');
          if (t === 'light' || t === 'dark') localStorage.setItem('theme-toggle', t);
        }
      })();
    </script>
    <ThemeScript />
  </head>
  <body class="font-sans antialiased overflow-hidden h-screen">
    <slot />
  </body>
</html>

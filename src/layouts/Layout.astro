---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Igor Oliveira | Software Developer',
  description = 'Software developer specializing in automation, production-ready backends, and integrations.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Anti-flash: apply theme before first paint -->
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
      const theme = stored ?? (prefersLight ? 'light' : 'dark');
      document.documentElement.classList.toggle('light', theme === 'light');
    </script>
  </head>
  <body class="font-sans antialiased overflow-hidden h-screen">
    <slot />
  </body>
</html>
